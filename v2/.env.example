# ============================================================
# V2 Memory Loop — 环境变量模板
# 复制为 .env 并填入真实值。.env 已被 .gitignore 排除。
# ============================================================

# --- PostgreSQL（业务 + mem0 共用实例） ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
BUSINESS_DB=ai_companion

# --- Qdrant ---
QDRANT_PORT=6333

# --- mem0 Server ---
MEM0_SERVER_PORT=8900

# --- LLM API（DeepSeek 或其他 OpenAI 兼容接口） ---
# mem0 用这个 key 做 Memory 抽取 LLM 调用
# 注意：Embedding 不使用此 Key——DeepSeek 不提供 embedding API
# mem0-server 硬编码使用 fastembed 本地模型（BAAI/bge-small-zh-v1.5），无需 API Key
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1

# --- mem0 LLM 配置（Memory 抽取用） ---
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=deepseek-chat
MEM0_LLM_API_KEY=${LLM_API_KEY}
MEM0_LLM_BASE_URL=https://api.deepseek.com/v1

# --- Dify Chatflow API ---
DIFY_API_URL=http://localhost:5001/v1
DIFY_API_KEY=app-your-dify-chatflow-key

# --- Next.js ---
NEXT_PUBLIC_API_BASE=http://localhost:3000

# --- 业务数据库连接（Next.js 用） ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_companion

# --- mem0 Server 连接（Next.js 用） ---
MEM0_API_URL=http://localhost:8900

# --- Demo 用户 ---
DEMO_USER_ID=demo-alice
DEMO_USER_NICKNAME=小鹿
